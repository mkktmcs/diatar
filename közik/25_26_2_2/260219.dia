[12]
caption= 
lines=3
line0=Szent John Henry Newman nem a teljesítmény, hanem a tökéletesség útját 
line1=javasolta, amely az Istennel való kapcsolatot ápolja. Ez az igazi "teljesítmény" a 
line2=hívő ember életében, ha ezt minden nap megteszi: 
soundfile=
fotofile=

[13]
caption= 
lines=6
line0=„Ha azt kérdezed, mit kell tenned, hogy tökéletes legyél, akkor az a feleletem, 
line1=hogy 
line2= 
line3=ne lustálkodj reggel az ágyban, amikor eljött az ideje, hogy felkelj, 
line4= 
line5=első gondolataidban Istenhez fordulj, 
soundfile=
fotofile=

[14]
caption= 
lines=5
line0=áhítattal látogasd meg a legszentebb Oltáriszentséget, 
line1= 
line2=mondd el áhítattal az Úrangyalát, 
line3= 
line4=Isten dicsőségére egyél és igyál, 
soundfile=
fotofile=

[15]
caption= 
lines=5
line0=odafigyeléssel mondd a rózsafüzért, 
line1= 
line2=légy összeszedett, 
line3= 
line4=tartsd távol magad a rossz gondolatoktól, 
soundfile=
fotofile=

[16]
caption= 
lines=5
line0=rendesen végezd az esti elmélkedést, 
line1= 
line2=mindennap vizsgáld meg a lelkiismeretedet, 
line3= 
line4=este idejében térj nyugovóra – és máris tökéletes vagy.” 
soundfile=
fotofile=

[17]
caption= 
lines=1
line0=Megteszek minden tőlem telhetőt? 
